devtools::check("./icare-git/")
# 保存为 diagnose_r_error.R，放在包目录外执行
# 或者直接在 R 中逐行运行
diagnose_r_error <- function(pkg_path = ".") {
# 确保路径正确
pkg_path <- normalizePath(pkg_path)
r_dir <- file.path(pkg_path, "R")
if (!dir.exists(r_dir)) {
stop("R directory not found in ", pkg_path)
}
r_files <- list.files(r_dir, pattern = "\\.R$", full.names = TRUE, recursive = TRUE)
if (length(r_files) == 0) {
cat("No R files found.\n")
return(invisible(NULL))
}
cat("========================================\n")
cat("Diagnosing 'object 'r' not found' error\n")
cat("========================================\n")
# ========== 方法1：逐文件加载并捕获错误 ==========
cat("\n[Method 1] Sequential source with error location...\n")
old_opt <- options(show.error.locations = TRUE)
on.exit(options(old_opt), add = TRUE)
error_files <- list()
for (f in r_files) {
rel_path <- gsub(paste0("^", normalizePath(pkg_path), "/"), "", f)
cat(sprintf("  %s ... ", rel_path), flush = TRUE)
ok <- tryCatch({
# 在新的环境中 source，避免污染
env <- new.env()
source(f, keep.source = TRUE, local = env, echo = FALSE, verbose = FALSE)
TRUE
}, error = function(e) {
# 捕获错误信息
msg <- conditionMessage(e)
# 尝试提取行号（可能包含在消息中）
cat("ERROR\n")
cat(sprintf("    File: %s\n", rel_path))
cat(sprintf("    Message: %s\n", msg))
# 尝试从错误消息中提取行号
line_info <- regmatches(msg, regexpr("line [0-9]+", msg))
if (length(line_info) > 0) {
cat(sprintf("    %s\n", line_info))
}
# 保存错误信息
error_files[[rel_path]] <<- msg
FALSE
})
if (ok) {
cat("OK\n")
}
}
if (length(error_files) > 0) {
cat("\n========================================\n")
cat("Error summary:\n")
for (nm in names(error_files)) {
cat(sprintf("  %s: %s\n", nm, error_files[[nm]]))
}
} else {
cat("\nNo errors found during source().\n")
}
# ========== 方法2：静态扫描变量 'r' ==========
cat("\n========================================\n")
cat("[Method 2] Static scan for variable 'r' usage...\n")
# 使用 codetools 检测未定义变量
if (!requireNamespace("codetools", quietly = TRUE)) {
cat("Package 'codetools' not installed, skipping static analysis.\n")
} else {
find_global_r <- function(expr) {
globals <- codetools::findGlobals(expr, merge = FALSE)$functions
if ("r" %in% globals) {
return(TRUE)
}
# 也检查可能的变量名 'r'（但 findGlobals 会区分函数和变量）
# 我们遍历所有符号
all_symbols <- codetools::collectUsage(expr, report = function(x) {})
# 更简单：直接递归查找符号 'r'
# 我们使用 codetools::findGlobals 的变量列表
vars <- codetools::findGlobals(expr, merge = FALSE)$variables
if ("r" %in% vars) {
return(TRUE)
}
return(FALSE)
}
for (f in r_files) {
rel_path <- gsub(paste0("^", normalizePath(pkg_path), "/"), "", f)
expr <- tryCatch(parse(f, keep.source = TRUE), error = function(e) NULL)
if (is.null(expr)) next
# 逐行或逐表达式检查
has_r <- FALSE
for (e in expr) {
if (find_global_r(e)) {
has_r <- TRUE
break
}
}
if (has_r) {
cat(sprintf("  %s: contains usage of variable 'r'\n", rel_path))
# 显示具体行
src <- attr(expr, "srcref")
if (!is.null(src)) {
for (i in seq_along(expr)) {
if (find_global_r(expr[[i]])) {
sr <- src[[i]]
if (!is.null(sr)) {
line <- sr[1]
# 获取该行内容
if (line <= length(readLines(f))) {
content <- readLines(f, warn = FALSE)[line]
cat(sprintf("    Line %d: %s\n", line, content))
}
}
}
}
}
}
}
}
# ========== 方法3：直接搜索包含 'r' 的代码行 ==========
cat("\n========================================\n")
cat("[Method 3] Search for bare 'r' in R files...\n")
for (f in r_files) {
rel_path <- gsub(paste0("^", normalizePath(pkg_path), "/"), "", f)
lines <- readLines(f, warn = FALSE)
# 查找行中包含单独 'r' 但不是注释或字符串中的可能性（但简单起见，只找包含 r 且可能为变量）
# 我们搜索模式：\br\b 作为完整单词
pattern <- "\\br\\b"
hits <- grep(pattern, lines, perl = TRUE, value = FALSE)
if (length(hits) > 0) {
cat(sprintf("  %s:\n", rel_path))
for (ln in hits) {
# 检查该行是否在注释中
line_content <- lines[ln]
# 去除字符串和注释中的匹配
# 简单的启发式：如果 # 在行首或前导空格，跳过
if (grepl("^\\s*#", line_content)) next
# 去除字符串内容
# 这里不做复杂处理，仅显示
cat(sprintf("    Line %d: %s\n", ln, trimws(line_content)))
}
}
}
cat("\n========================================\n")
cat("Diagnosis completed.\n")
}
# 使用示例（在包根目录外运行）
diagnose_r_error("./icare-git")
