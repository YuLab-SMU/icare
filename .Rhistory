diagnose_r_error("./icare-git")
# 保存为 find_r.R
find_r <- function(pkg_path = ".") {
pkg_path <- normalizePath(pkg_path)
r_dir <- file.path(pkg_path, "R")
if (!dir.exists(r_dir)) {
stop("R directory not found")
}
files <- list.files(r_dir, pattern = "\\.R$", full.names = TRUE, recursive = TRUE)
if (length(files) == 0) {
cat("No R files found.\n")
return(invisible(NULL))
}
cat("\n========================================\n")
cat("Searching for identifier 'r' in R code...\n")
cat("========================================\n")
found <- list()
for (f in files) {
rel_path <- gsub(paste0("^", normalizePath(pkg_path), "/"), "", f)
content <- readLines(f, warn = FALSE)
# 使用 parse 获取语法树（需要 keep.source = TRUE）
parsed <- tryCatch(parse(f, keep.source = TRUE), error = function(e) NULL)
if (is.null(parsed)) {
cat(sprintf("  %s: parse error, skipping\n", rel_path))
next
}
# 获取每个表达式的源码引用
srcref <- attr(parsed, "srcref")
if (is.null(srcref)) {
# 如果无法获取，使用 grep 粗略搜索
hits <- grep("\\br\\b", content, perl = TRUE)
if (length(hits) > 0) {
cat(sprintf("  %s: line(s) %s\n", rel_path, paste(hits, collapse=", ")))
for (h in hits) {
cat(sprintf("    %s\n", trimws(content[h])))
}
}
next
}
# 遍历每个顶层表达式
for (i in seq_along(parsed)) {
expr <- parsed[[i]]
sr <- srcref[[i]]
if (is.null(sr)) next
# 获取该表达式的起始行和结束行
start_line <- sr[1]
end_line <- sr[3]
# 在该表达式中查找符号 'r'
# 使用 getParseData 获取详细解析信息（针对该表达式）
# 但 getParseData 只能用于整个 parse 结果？可以传入 parsed 整体，再过滤。
pd <- getParseData(parsed, includeText = FALSE)
if (is.null(pd)) next
# 找到属于这个表达式的行范围
sub_pd <- pd[pd$line1 >= start_line & pd$line2 <= end_line, ]
if (nrow(sub_pd) == 0) next
# 查找 token = SYMBOL 且 text == "r" 的行
r_tokens <- sub_pd[sub_pd$token == "SYMBOL" & sub_pd$text == "r", ]
if (nrow(r_tokens) > 0) {
# 存在 r 符号
# 收集该表达式的行内容
expr_lines <- content[start_line:end_line]
found[[rel_path]] <- c(found[[rel_path]], list(
lines = expr_lines,
start = start_line,
end = end_line,
r_lines = r_tokens$line1
))
}
}
}
if (length(found) == 0) {
cat("No occurrence of 'r' as a symbol found.\n")
return(invisible(NULL))
}
cat("\nFound 'r' as symbol in the following files:\n")
for (file in names(found)) {
cat(sprintf("\nFile: %s\n", file))
for (entry in found[[file]]) {
cat(sprintf("  Lines %d-%d:\n", entry$start, entry$end))
for (i in seq_along(entry$lines)) {
line_num <- entry$start + i - 1
# 标记含有 r 的行
marker <- if (line_num %in% entry$r_lines) " >>>" else "    "
cat(sprintf("  %s %d: %s\n", marker, line_num, trimws(entry$lines[i])))
}
}
}
cat("\n========================================\n")
cat("If 'r' appears in a function parameter default, fix it.\n")
cat("If it's from a pipe operator like %>>%, ensure proper import.\n")
}
# 运行
find_r("./icare-git")
# 保存为 diagnose.R，在包目录外运行
diagnose_install_error <- function(pkg_path = ".") {
pkg_path <- normalizePath(pkg_path)
cat("========================================\n")
cat("Diagnosing 'object 'r' not found' error\n")
cat("========================================\n")
# 检查 data/ 目录中的 RData 或 rda 文件
data_dir <- file.path(pkg_path, "data")
if (dir.exists(data_dir)) {
data_files <- list.files(data_dir, pattern = "\\.(RData|rda)$", full.names = TRUE)
if (length(data_files) > 0) {
cat("\nChecking data files for object 'r':\n")
for (f in data_files) {
env <- new.env()
tryCatch({
load(f, envir = env)
if ("r" %in% ls(env)) {
cat(sprintf("  %s: contains object 'r'\n", basename(f)))
}
}, error = function(e) {
cat(sprintf("  %s: error loading: %s\n", basename(f), e$message))
})
}
}
}
# 检查 R 文件中是否有参数默认值 = r
r_files <- list.files(file.path(pkg_path, "R"), pattern = "\\.R$", full.names = TRUE, recursive = TRUE)
cat("\nChecking function default arguments for '= r':\n")
found <- FALSE
for (f in r_files) {
lines <- readLines(f, warn = FALSE)
for (i in seq_along(lines)) {
if (grepl("=\\s*r\\b", lines[i]) && !grepl("^\\s*#", lines[i])) {
cat(sprintf("  %s line %d: %s\n", basename(f), i, trimws(lines[i])))
found <- TRUE
}
}
}
if (!found) cat("  None found.\n")
# 尝试用 devtools::load_all 并捕获错误，显示堆栈
cat("\nAttempting devtools::load_all() to capture error...\n")
if (!requireNamespace("devtools", quietly = TRUE)) {
cat("devtools not installed, skipping.\n")
} else {
# 设置错误处理
old_error <- getOption("error")
options(error = function() {
cat("\n=== ERROR CAUGHT ===\n")
cat("Error message:", geterrmessage(), "\n")
cat("\nCall stack:\n")
traceback(2)
# 尝试显示当前环境
cat("\nCurrent environment variables:\n")
print(ls(envir = parent.frame()))
# 尝试读取文件内容
if (exists(".file")) cat("File:", get(".file"), "\n")
if (exists(".line")) cat("Line:", get(".line"), "\n")
options(error = old_error)  # 恢复
})
tryCatch({
devtools::load_all(pkg_path, quiet = FALSE)
}, error = function(e) {
cat("\nError in load_all:\n")
print(e)
})
options(error = old_error)
}
cat("\n========================================\n")
cat("Diagnosis complete.\n")
}
# 运行
diagnose_install_error("./icare-git")
devtools::check("./icare-git/")
options(error = function() {
cat("\n=== ERROR DETAILS ===\n")
cat("Message:", geterrmessage(), "\n")
cat("Call stack:\n")
traceback(2)
# 显示当前环境
env <- parent.frame()
cat("Objects in current environment:\n")
print(ls(env))
cat("Search path:\n")
print(search())
})
devtools::load_all("./icare-git/", quiet = FALSE)
devtools::check("./icare-git/")
devtools::document("./icare-git/")
devtools::check("./icare-git/")
devtools::check("./icare-git/")
setwd("./icare-git/")
data_files <- list.files("data", pattern = "\\.(RData|rda)$", full.names = TRUE)
for (f in data_files) {
cat("Loading", basename(f), "... ")
env <- new.env()
ok <- tryCatch({
load(f, envir = env)
TRUE
}, error = function(e) {
cat("ERROR:", e$message, "\n")
FALSE
})
if (ok) {
cat("OK, objects:", paste(ls(env), collapse = ", "), "\n")
# 检查是否有对象名为 r
if ("r" %in% ls(env)) {
cat("  -> WARNING: object 'r' found in this file\n")
}
}
}
# 加载包（devtools::load_all 已成功）
devtools::load_all("./icare-git/", quiet = TRUE)
# 获取所有导出和非导出函数
funcs <- ls(all.names = TRUE, envir = asNamespace("icare"))
# 检查每个函数的默认参数
for (f in funcs) {
if (is.function(get(f, envir = asNamespace("icare")))) {
args <- formals(get(f, envir = asNamespace("icare")))
for (arg in names(args)) {
val <- args[[arg]]
if (is.symbol(val) && val == "r") {
cat("Function", f, "has default argument", arg, "= r\n")
}
}
}
}
View(r)
View(r)
str(r)
rm(list=ls())
devtools::check("./icare-git/")
